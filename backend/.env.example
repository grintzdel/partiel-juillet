# Port d'écoute du serveur HTTP
PORT=3000

# URI de connexion MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/eventhub

# Secret utilisé pour signer les tokens JWT (mettre une valeur longue et aléatoire)
JWT_SECRET=change-me-with-a-long-random-secret

# Durée de validité des tokens JWT
JWT_EXPIRES_IN=7d
