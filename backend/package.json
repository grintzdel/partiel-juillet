{
  "name": "backend",
  "version": "1.0.0",
  "description": "Mini API REST de gestion d'événements - EventHub EEMI",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "db:sync": "tsx scripts/db-sync.ts",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit"
  },
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "eventhub"
  ],
  "author": "EEMI",
  "license": "MIT",
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
